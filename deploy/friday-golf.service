[Unit]
Description=Friday Golf Scheduler & Dashboard
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/friday-golf
EnvironmentFile=/opt/friday-golf/.env
ExecStart=/opt/friday-golf/venv/bin/python main.py
Restart=always
RestartSec=10

# Allow headed Chromium for WebTrac scraping (Cloudflare bypass)
Environment=DISPLAY=:99

[Install]
WantedBy=multi-user.target
